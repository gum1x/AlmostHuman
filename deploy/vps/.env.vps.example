# Copy to .env.vps on the VPS and fill in real values.
# Then: docker compose --env-file .env.vps up -d

# === Telegram (required) ===
TG_API_ID=
TG_API_HASH=
TG_PHONE=+10000000000
TG_SESSION_NAME=session
CONVERSATION_TG_SESSION_NAME=conversation

# Comma-separated chat IDs the system should monitor / respond in
MONITORED_CHAT_IDS=
ACTIVE_CHAT_IDS=

MONITOR_PRIVATE_DMS=true

# === Main AI (smart cognition layer) ===
# Use a REAL xAI key. The Grok model does perception + decision + plan (natural timing,
# who to reply to, what meaning/intent). This is the "control what we are actually doing" part.
# (Your local LoRA never sees the full reasoning load; it only phrases.)
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1

# === Hybrid architecture (recommended for VPS) ===
# Smart model (Grok via real xAI key) handles cognition, natural response decisions,
# target selection, risk, and high-level PLAN/intent ("what we are actually doing").
# Local fine-tuned model (your LoRA) ONLY phrases the final short text in group voice.
# This is the upgrade: smart controls the brain, local owns the voice.
LOCAL_STYLE_REWRITE_ENABLED=true
# http mode + the inference server you run on the VPS host (outside the container)
LOCAL_INFERENCE_MODE=http
LOCAL_INFERENCE_URL=http://172.17.0.1:8765/generate

# Local style paths (only used if you fall back to subprocess mode; http is preferred on VPS)
LOCAL_STYLE_PYTHON=python3
# Adjust these paths if your VPS username or layout is different
LOCAL_STYLE_CHAT_SCRIPT=/home/USER/telegram-style-ai/chat.py
LOCAL_STYLE_MODEL_PATH=/home/USER/telegram-style-ai/output/merged-model
LOCAL_STYLE_TIMEOUT_SECONDS=180

# Host path to your style model dir (used in docker-compose volume).
# Change only if your VPS username or base path differs from /home/USER.
LOCAL_STYLE_MOUNT_HOST=/home/USER/telegram-style-ai

# You also need a real XAI key (not sk-local) so the smart model can do the decision/plan layer:
# XAI_API_KEY=xai-...
# XAI_BASE_URL=https://api.x.ai/v1

# === Internal services (usually leave as-is) ===
DATABASE_URL=postgresql+asyncpg://ci_user:ci_pass@postgres:5432/telegram_ci
REDIS_URL=redis://redis:6379/0

LOG_LEVEL=INFO
LOG_JSON=true

# Optional tuning
WORKER_POOL_SIZE=5
