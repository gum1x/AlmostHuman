TG_API_ID=
TG_API_HASH=
TG_PHONE=
TG_SESSION_NAME=session
MONITORED_CHAT_IDS=
MONITOR_PRIVATE_DMS=true

CONVERSATION_TG_SESSION_NAME=conversation
ACTIVE_CHAT_IDS=

ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=

LOCAL_STYLE_REWRITE_ENABLED=false
LOCAL_STYLE_PYTHON=
LOCAL_STYLE_CHAT_SCRIPT=
LOCAL_STYLE_MODEL_PATH=
LOCAL_STYLE_TIMEOUT_SECONDS=120

# === Local / self-hosted model support (for VPS) ===
# Point the main brain (perception/decision/reflection) at any OpenAI-compatible server.
# Use a dummy key; the client will send "Bearer sk-local" if XAI_API_KEY is empty.
# XAI_BASE_URL=http://host.docker.internal:11434/v1     # example for Ollama on Docker Desktop
# XAI_BASE_URL=http://172.17.0.1:8000/v1                # common Docker bridge IP on Linux VPS
# Then set the actual model names in config.toml:
#   [ai]
#   perception_model = "qwen2.5-1.5b-instruct"   # or your local model name
#   decision_model = "qwen2.5-1.5b-instruct"
#
# For the fine-tuned style rewriter (the Qwen at /home/USER/telegram-style-ai):
# LOCAL_STYLE_REWRITE_ENABLED=true
# LOCAL_STYLE_PYTHON=python3
# LOCAL_STYLE_CHAT_SCRIPT=/home/USER/telegram-style-ai/chat.py   # or whatever your wrapper script is called
# LOCAL_STYLE_MODEL_PATH=/home/USER/telegram-style-ai/output/merged-model
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
# Set to true to run conversation_engine without a real API key (FakeAiClient; no replies sent by model)
ALLOW_FAKE_AI=false

# For docker volume (VPS local style model)
LOCAL_STYLE_MOUNT_HOST=/home/USER/telegram-style-ai

# === Timing classifier (when-to-respond ML gate) ===
# On by default: a learned logistic-regression model scores each incoming message
# and skips the expensive perception+decision LLM calls below threshold (the
# shipped ~6% reply cadence). models/timing_classifier_v2.json is calibrated on
# the original sample data — retrain on your own chat export for best results.
# TIMING_CLASSIFIER_ENABLED=false        # disable the ML gate (fall back to heuristic gate)
# TIMING_CLASSIFIER_SHADOW=true          # score + log "would-fire" without acting (measure first)
# TIMING_CLASSIFIER_MODEL_PATH=models/timing_classifier_v2.json

DATABASE_URL=postgresql+asyncpg://ci_user:ci_pass@localhost:5432/telegram_ci
REDIS_URL=redis://localhost:6379/0

LOG_LEVEL=INFO
LOG_JSON=true
